{
  "compilerOptions": {
    "composite": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./dist/tsconfig.node.tsbuildinfo",
    "noEmit": true
  },
  "include": ["vite.config.ts", "server/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
